{
  "id": "stage_defeat_flow",
  "name": "Stage enters and ends in defeat",
  "setup": {
    "roomId": "test_room_stage_defeat",
    "stageId": "stage_slime_training",
    "starterDeckId": "co_op_starter",
    "randomSeed": 24681357,
    "topology": 0,
    "players": [
      {
        "playerId": "p1",
        "displayName": "Alpha"
      }
    ]
  },
  "steps": [
    {
      "action": "snapshot",
      "snapshotTag": "initial_stage"
    },
    {
      "action": "debug_set_player_hp",
      "targetUnitId": "p1",
      "debugValue": 1,
      "snapshotTag": "after_set_hp"
    },
    {
      "action": "end_turn",
      "actorPlayerId": "p1",
      "snapshotTag": "after_monster_kill"
    }
  ],
  "assertions": [
    {
      "type": "snapshot_contains",
      "message": "Scenario should start in slime stage",
      "expected": "\"stageId\":\"stage_slime_training\"",
      "actualPath": "initial_stage"
    },
    {
      "type": "snapshot_contains",
      "message": "Defeat scenario should load slime encounter",
      "expected": "\"encounterId\":\"slime_intro\"",
      "actualPath": "initial_stage"
    },
    {
      "type": "snapshot_contains",
      "message": "After monster turn should enter defeat phase",
      "expected": "\"phase\":4",
      "actualPath": "after_monster_kill"
    },
    {
      "type": "snapshot_contains",
      "message": "Player hp should be zero after lethal hit",
      "expected": "\"hp\":0",
      "actualPath": "after_monster_kill"
    }
  ]
}
