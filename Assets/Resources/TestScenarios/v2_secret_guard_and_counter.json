{
  "scenarioVersion": 2,
  "id": "v2_secret_guard_and_counter",
  "name": "V2 护卫与反制奥秘触发",
  "setup": {
    "roomId": "v2_secret_room",
    "stageId": "stage_boss_debug",
    "starterDeckId": "co_op_starter",
    "randomSeed": 20260320,
    "players": [
      {
        "playerId": "p1",
        "displayName": "Alpha"
      },
      {
        "playerId": "p2",
        "displayName": "Beta"
      }
    ]
  },
  "steps": [
    {
      "action": "debug_clear_hand",
      "actorPlayerId": "p1"
    },
    {
      "action": "debug_clear_hand",
      "actorPlayerId": "p2"
    },
    {
      "action": "debug_add_card_to_hand",
      "actorPlayerId": "p1",
      "cardId": "utility_secret_guard"
    },
    {
      "action": "debug_add_card_to_hand",
      "actorPlayerId": "p1",
      "cardId": "utility_secret_counter"
    },
    {
      "action": "debug_add_card_to_hand",
      "actorPlayerId": "p2",
      "cardId": "warrior_taunt"
    },
    {
      "action": "play_card",
      "actorPlayerId": "p1",
      "cardInstanceId": "card:utility_secret_guard",
      "targetFaction": 1,
      "targetUnitId": "p1",
      "targetArea": 0,
      "snapshotTag": "after_guard"
    },
    {
      "action": "play_card",
      "actorPlayerId": "p1",
      "cardInstanceId": "card:utility_secret_counter",
      "targetFaction": 1,
      "targetUnitId": "p1",
      "targetArea": 0,
      "snapshotTag": "after_counter"
    },
    {
      "action": "play_card",
      "actorPlayerId": "p2",
      "cardInstanceId": "card:warrior_taunt",
      "targetFaction": 1,
      "targetUnitId": "p2",
      "targetArea": 0,
      "snapshotTag": "after_taunt_target"
    },
    {
      "action": "end_turn",
      "actorPlayerId": "p1"
    },
    {
      "action": "end_turn",
      "actorPlayerId": "p2",
      "snapshotTag": "after_end_turns"
    },
    {
      "action": "begin_monster_turn",
      "snapshotTag": "after_monster_turn_begin"
    },
    {
      "action": "resolve_monster_turn",
      "snapshotTag": "after_monster_turn"
    }
  ],
  "assertions": [
    {
      "type": "player_status_equals",
      "actualPath": "after_guard",
      "playerId": "p1",
      "statusId": "SecretGuard",
      "expectedInt": 1,
      "message": "护卫奥秘已挂上"
    },
    {
      "type": "player_status_equals",
      "actualPath": "after_counter",
      "playerId": "p1",
      "statusId": "SecretCounterattack",
      "expectedInt": 4,
      "message": "反制奥秘已挂上"
    },
    {
      "type": "player_status_equals",
      "actualPath": "after_monster_turn",
      "playerId": "p1",
      "statusId": "SecretGuard",
      "expectedInt": 0,
      "message": "护卫触发后被消耗"
    },
    {
      "type": "player_status_equals",
      "actualPath": "after_monster_turn",
      "playerId": "p1",
      "statusId": "SecretCounterattack",
      "expectedInt": 0,
      "message": "反制触发后被消耗"
    },
    {
      "type": "monster_core_hp_equals",
      "actualPath": "after_monster_turn",
      "expectedInt": 56,
      "message": "反制造成4点怪物核心伤害"
    },
    {
      "type": "event_contains",
      "actualPath": "after_monster_turn",
      "eventId": "secret_guard_redirect",
      "statusId": "SecretGuard",
      "message": "护卫奥秘触发"
    },
    {
      "type": "event_contains",
      "actualPath": "after_monster_turn",
      "eventId": "secret_counter",
      "statusId": "SecretCounterattack",
      "message": "反制奥秘触发"
    },
    {
      "type": "phase_equals",
      "actualPath": "after_monster_turn",
      "expected": "PlayerTurnStart",
      "message": "怪物行动后进入玩家回合开始阶段"
    }
  ]
}
