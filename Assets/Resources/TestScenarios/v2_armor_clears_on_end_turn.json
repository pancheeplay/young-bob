{
  "scenarioVersion": 2,
  "id": "v2_armor_clears_on_end_turn",
  "name": "V2 armor clears on end turn",
  "setup": {
    "roomId": "v2_armor_clear_room",
    "stageId": "stage_boss_debug",
    "starterDeckId": "co_op_starter",
    "randomSeed": 20260320,
    "players": [
      {
        "playerId": "p1",
        "displayName": "Alpha"
      }
    ]
  },
  "steps": [
    {
      "action": "debug_clear_hand",
      "actorPlayerId": "p1"
    },
    {
      "action": "debug_add_card_to_hand",
      "actorPlayerId": "p1",
      "cardId": "warrior_iron_wall"
    },
    {
      "action": "play_card",
      "actorPlayerId": "p1",
      "cardInstanceId": "card:warrior_iron_wall",
      "targetFaction": 1,
      "targetUnitId": "p1",
      "targetArea": 0,
      "snapshotTag": "after_gain_armor"
    },
    {
      "action": "end_turn",
      "actorPlayerId": "p1",
      "snapshotTag": "after_end_turn"
    }
  ],
  "assertions": [
    {
      "type": "player_field_equals",
      "actualPath": "after_gain_armor",
      "playerId": "p1",
      "field": "armor",
      "expectedInt": 8,
      "message": "iron wall grants armor"
    },
    {
      "type": "player_field_equals",
      "actualPath": "after_end_turn",
      "playerId": "p1",
      "field": "armor",
      "expectedInt": 0,
      "message": "armor is removed when the player's turn ends"
    },
    {
      "type": "event_contains",
      "actualPath": "after_end_turn",
      "eventId": "lose_armor",
      "target": "Alpha",
      "field": "amount",
      "expectedInt": 8,
      "message": "end turn emits armor loss event"
    }
  ]
}
