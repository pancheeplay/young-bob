{
  "id": "stage_progression_victory",
  "name": "Stage enters, progresses encounter, and wins",
  "setup": {
    "roomId": "test_room_stage_progression",
    "stageId": "stage_trial_1",
    "starterDeckId": "co_op_starter",
    "randomSeed": 24681357,
    "topology": 0,
    "players": [
      {
        "playerId": "p1",
        "displayName": "Alpha"
      }
    ]
  },
  "steps": [
    {
      "action": "snapshot",
      "snapshotTag": "initial_stage"
    },
    {
      "action": "debug_damage_monster",
      "debugValue": 1000,
      "snapshotTag": "after_debug_kill_first"
    },
    {
      "action": "end_turn",
      "actorPlayerId": "p1",
      "snapshotTag": "after_first_encounter_clear"
    },
    {
      "action": "debug_damage_monster",
      "debugValue": 1000,
      "snapshotTag": "after_debug_kill_second"
    },
    {
      "action": "end_turn",
      "actorPlayerId": "p1",
      "snapshotTag": "after_stage_victory"
    }
  ],
  "assertions": [
    {
      "type": "snapshot_contains",
      "message": "Scenario should start in stage_trial_1",
      "expected": "\"stageId\":\"stage_trial_1\"",
      "actualPath": "initial_stage"
    },
    {
      "type": "snapshot_contains",
      "message": "First encounter should be slime_intro",
      "expected": "\"encounterId\":\"slime_intro\"",
      "actualPath": "initial_stage"
    },
    {
      "type": "snapshot_contains",
      "message": "After first clear should enter dragon encounter",
      "expected": "\"encounterId\":\"dragon_curse_boss\"",
      "actualPath": "after_first_encounter_clear"
    },
    {
      "type": "snapshot_contains",
      "message": "Encounter index should advance to 1",
      "expected": "\"stageEncounterIndex\":1",
      "actualPath": "after_first_encounter_clear"
    },
    {
      "type": "snapshot_contains",
      "message": "After second clear should reach victory phase",
      "expected": "\"phase\":3",
      "actualPath": "after_stage_victory"
    }
  ]
}
