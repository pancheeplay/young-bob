{
  "scenarioVersion": 2,
  "id": "v2_secret_armor_on_hit",
  "name": "V2 受击奥秘转护甲",
  "setup": {
    "roomId": "v2_secret_armor_room",
    "stageId": "stage_slime_training",
    "starterDeckId": "co_op_starter",
    "randomSeed": 20260320,
    "players": [
      {
        "playerId": "p1",
        "displayName": "Alpha"
      }
    ]
  },
  "steps": [
    {
      "action": "debug_clear_hand",
      "actorPlayerId": "p1"
    },
    {
      "action": "debug_add_card_to_hand",
      "actorPlayerId": "p1",
      "cardId": "utility_secret_iron_echo"
    },
    {
      "action": "play_card",
      "actorPlayerId": "p1",
      "cardInstanceId": "card:utility_secret_iron_echo",
      "targetFaction": 1,
      "targetUnitId": "p1",
      "targetArea": 0,
      "snapshotTag": "after_secret_play"
    },
    {
      "action": "end_turn",
      "actorPlayerId": "p1",
      "snapshotTag": "after_end_turn"
    },
    {
      "action": "begin_monster_turn",
      "snapshotTag": "after_monster_turn_begin"
    },
    {
      "action": "resolve_monster_turn",
      "snapshotTag": "after_monster_turn"
    },
    {
      "action": "begin_player_turn",
      "snapshotTag": "after_armor_expired"
    }
  ],
  "assertions": [
    {
      "type": "player_status_equals",
      "actualPath": "after_secret_play",
      "playerId": "p1",
      "statusId": "SecretArmorOnHit",
      "expectedInt": 5,
      "message": "奥秘已挂上"
    },
    {
      "type": "player_status_equals",
      "actualPath": "after_monster_turn",
      "playerId": "p1",
      "statusId": "SecretArmorOnHit",
      "expectedInt": 0,
      "message": "受击后奥秘被消耗"
    },
    {
      "type": "player_field_equals",
      "actualPath": "after_monster_turn",
      "playerId": "p1",
      "field": "hp",
      "expectedInt": 21,
      "message": "先承受3点伤害"
    },
    {
      "type": "player_field_equals",
      "actualPath": "after_monster_turn",
      "playerId": "p1",
      "field": "armor",
      "expectedInt": 5,
      "message": "受击后获得5点护甲"
    },
    {
      "type": "player_status_duration_equals",
      "actualPath": "after_monster_turn",
      "playerId": "p1",
      "statusId": "TempArmor",
      "durationKind": "UntilTurnStart",
      "expectedInt": 1,
      "message": "secret armor grants temp armor with a single until-turn-start duration"
    },
    {
      "type": "phase_equals",
      "actualPath": "after_monster_turn",
      "expected": "PlayerTurnStart",
      "message": "怪物行动结算后停在玩家回合开始阶段"
    },
    {
      "type": "event_contains",
      "actualPath": "after_monster_turn",
      "eventId": "secret_gain_armor",
      "statusId": "SecretArmorOnHit",
      "field": "amount",
      "expectedInt": 5,
      "message": "受击后触发加护甲奥秘"
    },
    {
      "type": "event_sequence",
      "actualPath": "after_monster_turn",
      "expected": "monster_hit >> secret_gain_armor",
      "message": "先受击，再触发加护甲奥秘"
    },
    {
      "type": "player_field_equals",
      "actualPath": "after_armor_expired",
      "playerId": "p1",
      "field": "armor",
      "expectedInt": 0,
      "message": "玩家回合开始时护甲消失"
    },
    {
      "type": "phase_equals",
      "actualPath": "after_armor_expired",
      "expected": "PlayerTurn",
      "message": "begin_player_turn 进入玩家行动阶段"
    }
  ]
}
