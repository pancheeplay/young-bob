{
  "scenarioVersion": 2,
  "id": "v2_secret_strength_on_hit",
  "name": "V2 受击奥秘转力量",
  "setup": {
    "roomId": "v2_secret_strength_room",
    "stageId": "stage_slime_training",
    "starterDeckId": "co_op_starter",
    "randomSeed": 20260320,
    "players": [
      {
        "playerId": "p1",
        "displayName": "Alpha"
      }
    ]
  },
  "steps": [
    {
      "action": "debug_clear_hand",
      "actorPlayerId": "p1"
    },
    {
      "action": "debug_add_card_to_hand",
      "actorPlayerId": "p1",
      "cardId": "utility_secret_rising_fury"
    },
    {
      "action": "play_card",
      "actorPlayerId": "p1",
      "cardInstanceId": "card:utility_secret_rising_fury",
      "targetFaction": 1,
      "targetUnitId": "p1",
      "targetArea": 0,
      "snapshotTag": "after_secret_play"
    },
    {
      "action": "end_turn",
      "actorPlayerId": "p1",
      "snapshotTag": "after_monster_turn"
    },
    {
      "action": "debug_add_card_to_hand",
      "actorPlayerId": "p1",
      "cardId": "assassin_quick_jab"
    },
    {
      "action": "play_card",
      "actorPlayerId": "p1",
      "cardInstanceId": "card:assassin_quick_jab",
      "targetFaction": 2,
      "targetUnitId": "$part:body",
      "targetArea": 0,
      "snapshotTag": "after_buffed_attack"
    },
    {
      "action": "end_turn",
      "actorPlayerId": "p1",
      "snapshotTag": "after_buff_expired"
    }
  ],
  "assertions": [
    {
      "type": "player_status_equals",
      "actualPath": "after_secret_play",
      "playerId": "p1",
      "statusId": "SecretStrengthOnHit",
      "expectedInt": 2,
      "message": "奥秘已挂上"
    },
    {
      "type": "player_status_equals",
      "actualPath": "after_monster_turn",
      "playerId": "p1",
      "statusId": "SecretStrengthOnHit",
      "expectedInt": 0,
      "message": "受击后奥秘被消耗"
    },
    {
      "type": "player_status_equals",
      "actualPath": "after_monster_turn",
      "playerId": "p1",
      "statusId": "TempStrength",
      "expectedInt": 2,
      "message": "受击后获得2层临时力量"
    },
    {
      "type": "player_field_equals",
      "actualPath": "after_monster_turn",
      "playerId": "p1",
      "field": "hp",
      "expectedInt": 21,
      "message": "史莱姆攻击造成3点伤害"
    },
    {
      "type": "event_contains",
      "actualPath": "after_monster_turn",
      "eventId": "secret_gain_strength",
      "statusId": "SecretStrengthOnHit",
      "field": "amount",
      "expectedInt": 2,
      "message": "受击后触发加力量奥秘"
    },
    {
      "type": "event_sequence",
      "actualPath": "after_monster_turn",
      "expected": "monster_hit >> secret_gain_strength",
      "message": "先受击，再触发加力量奥秘"
    },
    {
      "type": "part_field_equals",
      "actualPath": "after_buffed_attack",
      "partId": "body",
      "field": "hp",
      "expectedInt": 19,
      "message": "临时力量让快刀造成3点伤害"
    },
    {
      "type": "player_status_equals",
      "actualPath": "after_buffed_attack",
      "playerId": "p1",
      "statusId": "TempStrength",
      "expectedInt": 2,
      "message": "本回合内临时力量仍然存在"
    },
    {
      "type": "player_status_equals",
      "actualPath": "after_buff_expired",
      "playerId": "p1",
      "statusId": "TempStrength",
      "expectedInt": 0,
      "message": "回合结束后临时力量消失"
    }
  ]
}
