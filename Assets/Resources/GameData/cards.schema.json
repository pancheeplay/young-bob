{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "cards.schema.json",
  "title": "Young Bob Card Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "cards"
  ],
  "properties": {
    "cards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/card"
      }
    }
  },
  "definitions": {
    "card": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "classTag",
        "targetType",
        "rangeHeights",
        "rangeDistance",
        "energyCost",
        "effectsSExpr"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "classTag": {
          "type": "string",
          "enum": [
            "Utility",
            "Priest",
            "Assassin",
            "Warrior",
            "Curse"
          ]
        },
        "targetType": {
          "type": "string",
          "enum": [
            "Self",
            "SingleAlly",
            "AllAllies",
            "OtherAlly",
            "MonsterPart",
            "AllMonsterParts",
            "SingleUnit",
            "Area"
          ]
        },
        "rangeHeights": {
          "type": "string",
          "enum": [
            "Both",
            "Ground",
            "Air"
          ]
        },
        "rangeDistance": {
          "type": "string",
          "enum": [
            "Both",
            "Near",
            "Far"
          ]
        },
        "rangeZones": {
          "type": "string",
          "enum": [
            "Both",
            "Front",
            "Back"
          ]
        },
        "energyCost": {
          "type": "integer",
          "minimum": 0
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "effectsSExpr": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
